@model IEnumerable<LobbyLink.DataAccess.Model.ItemInstance>

@{
    ViewData["Title"] = "Inventory";
}

<h1 class="text-center my-4">Inventory</h1>

<table class="table table-striped">
    <thead>
        <tr>
            <th>ItemInstance ID</th>
            <th>Item Name</th>
            <th>Description</th>
            <th>Account Owner</th>
            <th>Game</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ItemInstanceId</td>
                <td>@item.ItemDefinition.ItemName</td>
                <td>@item.ItemDefinition.ItemDescription</td>
                <td>@item.Account.Username</td>
                <td>@item.ItemDefinition.Game.GameTitle</td>
                <td>
                   <a asp-controller="Inventory"
                   asp-action="Sell"
                   asp-route-id="@item.ItemInstanceId"
                   class="btn btn-info btn-sm">
                   Details/Sell
                   </a>
                <td>
            </tr>
        }
    </tbody>
</table>