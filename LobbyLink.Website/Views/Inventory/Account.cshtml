@model IEnumerable<LobbyLink.Website.Models.InventoryItemViewModel>

@{
    ViewData["Title"] = "Inventory";
}

<h1 class="text-center my-4">Inventory</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["ErrorMessage"]
    </div>
}

@if (Model == null || Model.Count() == 0)
{
    <h3 class="text-center my-4">Ingen items for denne bruger</h3>
}
else
{
<table class="table table-striped">
    <thead>
        <tr>
            <th>ItemInstance ID</th>
            <th>Item Name</th>
            <th>Description</th>
            <th>Account Owner</th>
            <th>Game</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ItemInstanceId</td>
                    <td>@item.ItemName</td>
                    <td>@item.Description</td>
                    <td>@item.AccountOwner</td>
                    <td>@item.GameTitle</td>
                    <td>
                        @if (item.IsListedForSale)
                        {
                            <a asp-controller="Inventory"
                                   asp-action="InventoryInspect"
                                   asp-route-itemInstanceId="@item.ItemInstanceId"
                                   class="btn btn-info btn-sm">
                                Inspect
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Inventory"
                                   asp-action="InventoryInspect"
                                   asp-route-itemInstanceId="@item.ItemInstanceId"
                                   class="btn btn-warning btn-sm">
                                Details / Sell
                            </a>
                        }
                    </td>
                </tr>
            }
    </tbody>
</table>
}