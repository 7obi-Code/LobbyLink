@model IEnumerable<LobbyLink.DataAccess.Model.Listing>

@{
    ViewData["Title"] = "Marketplace";
}

<div class="container-fluid">
    <div class="row">

        <div class="col-md-3 border-end">
            <div class="p-3">
                <form method="get" asp-action="Listings">


                    <!-- Søgebar -->
                    <div class="mb-3 position-relative">
                        <input type="text"
                               id="searchInput"
                               name="search"
                               value="@Context.Request.Query["search"]"
                               class="form-control"
                               placeholder="Search skins..." />

                        <div id="searchResults"
                             class="list-group position-absolute w-100"
                             style="z-index:1000; max-height:200px; overflow-y:auto; display:none;">
                        </div>
                    </div>

                    <!-- Game filter -->
                    <select name="game" class="form-control mb-3">
                        <option value="">All Games</option>

                        @{
                            var selectedGame = Context.Request.Query["game"].ToString();
                        }

                        @foreach (string g in ViewBag.Games)
                        {
                            if (g == selectedGame)
                            {
                                <option value="@g" selected>@g</option>
                            }
                            else
                            {
                                <option value="@g">@g</option>
                            }
                        }
                    </select>

                    <!-- Pris filter -->
                    <label>Price Range</label>
                    <div class="row mb-3">
                        <div class="col">
                            <input name="minPrice"
                                   value="@Context.Request.Query["minPrice"]"
                                   type="number"
                                   class="form-control"
                                   placeholder="Min" />
                        </div>
                        <div class="col">
                            <input name="maxPrice"
                                   value="@Context.Request.Query["maxPrice"]"
                                   type="number"
                                   class="form-control"
                                   placeholder="Max" />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary">Apply Filters</button>

                    <a href="/Marketplace/Listings" class="btn btn-secondary mt-2">Clear</a>
                </form>
            </div>
        </div>

        <div class="col-md-9 p-4">

            <!-- Success besked ved køb seccess -->
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">
                    @TempData["SuccessMessage"]
                </div>
            }

            <!-- Fejl besked ved køb fejl -->
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-success">
                    @TempData["ErrorMessage"]
                </div>
            }


            <!-- Gemmer søgefiltre til konteksten af når man skal søge efter low/high -->
            @{
                var game = Context.Request.Query["game"];
                var min = Context.Request.Query["minPrice"];
                var max = Context.Request.Query["maxPrice"];
                var search = Context.Request.Query["search"];
            }

            <!-- Low/high knapper til at sorterer efter pris -->
            <div class="row mb-4">
                <div class="col text-end">

                    <a href="/Marketplace/Listings?game=@game&minPrice=@min&maxPrice=@max&search=@search&sort=low"
                           class="btn bg-white text-dark border me-2">
                        Low → High
                    </a>

                    <a href="/Marketplace/Listings?game=@game&minPrice=@min&maxPrice=@max&search=@search&sort=high"
                           class="btn bg-white text-dark border">
                        High → Low
                    </a>

                </div>
            </div>

            <!-- Item card i marketplace -->
            <div class="row">
                @foreach (var listing in Model)
                {
                    <div class="col-md-4 mb-4">
                        <div class="card text-center">

                            <div class="card-body">
                                <p>@listing.ItemInstance.ItemDefinition.ItemName</p>
                                <img src="/images/default.png" class="img-fluid" style="max-height:150px;" />
                                <p>Seller: @listing.SellerAccount.UserName</p>
                                <p class="fw-bold">PRICE: @listing.Price</p>
                                <hr />
                                <a asp-controller="Marketplace" 
                                asp-action="MarketInspect" 
                                asp-route-listingId="@listing.ListingId" 
                                class="btn btn-outline-primary">BUY</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>