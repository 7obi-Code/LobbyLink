@model IEnumerable<LobbyLink.DataAccess.Model.Listing>

@{
    ViewData["Title"] = "Marketplace";
}

<h1 class="text-center my-4">Marketplace</h1>

<div class="table-responsive">
    <table class="table table-dark table-striped">
        <thead>
            <tr>
                <th>Item ID</th>
                <th>Item Name</th>
                <th>Description</th>
                <th>Seller</th>
                <th>Game</th>
                <th>Price</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var listing in Model)
            {
                <tr>
                    <td>@listing.ItemInstanceId</td>
                    <td>@listing.ItemInstance.ItemDefinition?.ItemName</td>
                    <td>@listing.ItemInstance.ItemDefinition?.ItemDescription</td>
                    <td>@listing.Account?.Username</td>
                    <td>@listing.ItemInstance.ItemDefinition?.Game?.GameTitle</td>
                    <td>@listing.Price</td>
                    <td>
                        <a asp-controller="Marketplace"
                               asp-action="MarketInspect"
                               asp-route-itemInstanceId="@listing.ItemInstanceId"
                               asp-route-mode="buy"
                               class="btn btn-success">
                            Details / Buy
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>