@model LobbyLink.DataAccess.Model.Listing

@{
    ViewData["Title"] = "Inspect Item";
}

<h2 class="text-center my-4">Item Details</h2>

<div class="container d-flex justify-content-center">
    <div class="card bg-secondary text-light p-4 shadow-lg" style="width: 600px;">


        <h3 class="text-center">@Model.ItemInstance.ItemDefinition?.ItemName</h3>

        <hr />


        @if (!string.IsNullOrEmpty(Model.ItemInstance.ItemDefinition?.ItemImageUrl))
        {
            <div class="text-center mb-3">
                <img src="@Model.ItemInstance.ItemDefinition.ItemImageUrl"
                     class="img-fluid rounded"
                     style="max-height: 200px;" />
            </div>
        }


        <p><strong>Description:</strong><br /> @Model.ItemInstance.ItemDefinition?.ItemDescription</p>


        <p><strong>Game:</strong> @Model.ItemInstance.ItemDefinition?.Game?.GameTitle</p>


        <p><strong>Item ID:</strong> @Model.ItemInstanceId</p>
        <p><strong>Owner:</strong> @Model.ItemInstance.Account?.UserName</p>

        <hr />

        <form asp-controller="Marketplace" asp-action="Buy" asp-route-listingId="@Model.ListingId" method="post">
            <input type="number" name="buyerAccountId"
                   placeholder="Buyer Account ID"
                   class="form-control w-25 mx-auto" required />

            <div class="text-center mt-4">
                <button type="submit" class="btn btn-success btn-lg">
                    Buy Item
                </button>
            </div>

        </form>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-success">
                @TempData["ErrorMessage"]
            </div>
        }

    </div>
</div>